# MongoDB Atlas connection string
# Sign up at https://www.mongodb.com/cloud/atlas and create a free cluster
# Replace <username>, <password>, and <cluster> with your values
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/routeready?retryWrites=true&w=majority

# JWT Secret — use a random strong string in production
JWT_SECRET=routeready_secret_key_2024

# Server port
PORT=5000

# Frontend origin (use specific URL in production, * for development)
CLIENT_ORIGIN=*
